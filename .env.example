# Copy this file to .env and fill in real values.
# .env is gitignored — never committed.

# Gemini API key (Nano Banana = Gemini 2.5 Flash Image)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override Gemini model slugs if needed
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_IMAGE_PRO_MODEL=gemini-2.5-flash-image-preview

# Anthropic API key — required for caption_service (Spec 05).
# Without this, /api/caption returns 503. Get from console.anthropic.com.
ANTHROPIC_API_KEY=

# OpenAI API key — only needed if nano_banana_runner is run with --backend openai.
OPENAI_API_KEY=

# Cloudinary (already configured, keys for reference if you ever need to re-pull URLs)
CLOUDINARY_CLOUD_NAME=dkp42tunc
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- Deployment / ops (Cloudflare Tunnel) ---
# Tunnel UUID emitted by `cloudflared tunnel create savora-content`.
# Used by scripts/deploy/cloudflared/config.yml.
# CLOUDFLARED_TUNNEL_ID=
